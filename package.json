{
  "name": "inbox-to-md",
  "version": "0.1.0",
  "description": "Sync IMAP inboxes to Markdown files — one file per email, with YAML frontmatter",
  "type": "module",
  "bin": {
    "inbox-to-md": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "imap",
    "email",
    "markdown",
    "inbox",
    "sync",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chaidhat/inbox-to-md.git"
  },
  "homepage": "https://github.com/chaidhat/inbox-to-md#readme",
  "bugs": {
    "url": "https://github.com/chaidhat/inbox-to-md/issues"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "auth": "tsx src/auth.ts",
    "authcli": "tsx src/authcli.ts",
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "archive": "tsx src/archive.ts",
    "compact": "tsx src/compact.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.211",
    "imapflow": "^1.4.7",
    "turndown": "^7.2.4"
  }
}
